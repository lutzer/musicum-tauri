{
  "name": "audio-plugin-sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/audio-plugin-sdk/src",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test",
        "cwd": "libs/audio-plugin-sdk"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy -- -D warnings",
        "cwd": "libs/audio-plugin-sdk"
      }
    }
  }
}
