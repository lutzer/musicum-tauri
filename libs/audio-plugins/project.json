{
  "name": "audio-plugins",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/audio-plugins",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash test.sh",
        "cwd": "libs/audio-plugins"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy -- -D warnings",
        "cwd": "libs/audio-plugins/gain"
      }
    }
  }
}
